# LLM defaults
# Supported providers: zhipu, bailian, deepseek, openai
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5
LLM_API_KEY=
LLM_BASE_URL=

# Zhipu / BigModel
ZHIPU_API_KEY=your_key
ZHIPUAI_API_KEY=your_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-5

# Bailian / DashScope
BAILIAN_API_KEY=your_key
DASHSCOPE_API_KEY=your_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.5-plus

# DeepSeek
DEEPSEEK_API_KEY=your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Triple extraction pipeline
# This is intentionally isolated from the main chat/retrieval LLM config.
TRIPLE_LLM_MODEL=doubao-seed-2.0-pro
TRIPLE_LLM_API_KEY=your_key
TRIPLE_LLM_BASE_URL=https://api.ai.org.kg/v1
# Optional explicit provider list. When set, it overrides the per-provider fallback env vars below.
# Example:
# TRIPLE_LLM_PROVIDERS=[{"name":"primary","model":"mimo-v2-pro","api_key":"your_primary_key","base_url":"https://api.ai.org.kg/v1","weight":1,"enabled":true},{"name":"jmrai","model":"mimo-v2-pro","api_key":"your_jmrai_key","base_url":"https://jmrai.net/v1","weight":1,"enabled":true}]
TRIPLE_LLM_PROVIDERS=
# Optional second source for triple extraction.
# If JMRAI-specific API key / base URL are left empty, runtime falls back to LLM_API_KEY / LLM_BASE_URL.
TRIPLE_LLM_JMRAI_ENABLED=false
TRIPLE_LLM_JMRAI_NAME=jmrai
TRIPLE_LLM_JMRAI_MODEL=mimo-v2-pro
TRIPLE_LLM_JMRAI_API_KEY=
TRIPLE_LLM_JMRAI_BASE_URL=https://jmrai.net/v1
TRIPLE_LLM_JMRAI_WEIGHT=1

# OpenAI-compatible embeddings defaults
# Supported providers: bailian, openai
EMBEDDING_PROVIDER=bailian
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
CASE_QA_EMBEDDING_MODEL=
CASE_QA_EMBEDDING_DIM=1024

# OpenAI embeddings
OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Tavily web search
TAVILY_API_KEY=your_key
TAVILY_PROJECT=

# TCM fusion services
GRAPH_SERVICE_BASE_URL=http://127.0.0.1:8101
RETRIEVAL_SERVICE_BASE_URL=http://127.0.0.1:8102

# Graph service runtime (S3+ / NebulaGraph target)
GRAPH_BACKEND=nebula
NEBULA_HOST=127.0.0.1
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=tcm_kg
NEBULA_VID_MAX_LENGTH=64
NEBULA_TIMEOUT_MS=8000

# Retrieval service runtime (S2 / SuperMew hybrid retrieval)
MILVUS_URI=storage/milvus_retrieval.db
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection
RETRIEVAL_DENSE_DIM=2560
AUTO_MERGE_ENABLED=true
AUTO_MERGE_THRESHOLD=2
LEAF_RETRIEVE_LEVEL=3
RETRIEVAL_RERANK_ENDPOINT=
RETRIEVAL_RERANK_MODEL=
RETRIEVAL_RERANK_API_KEY=
